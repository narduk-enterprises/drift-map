{
  "name": "web",
  "type": "module",
  "private": true,
  "version": "1.8.7",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "sh ./scripts/db-migrate.sh --local",
    "db:seed": "wrangler d1 execute drift-map-db --local --file=node_modules/@narduk-enterprises/narduk-nuxt-template-layer/drizzle/seed.sql",
    "db:studio": "drizzle-kit studio",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck"
  },
  "dependencies": {
    "@drift-map/db": "workspace:*",
    "@narduk-enterprises/narduk-nuxt-template-layer": "workspace:*",
    "@narduk/eslint-config": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "nuxt": "^4.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.94",
    "@tailwindcss/vite": "^4.0.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.2",
    "nitro-cloudflare-dev": "^0.2.2",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.20.0"
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@7.3.1"
  },
  "volta": {
    "node": "22.22.0"
  }
}
